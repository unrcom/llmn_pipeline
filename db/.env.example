# --- PostgreSQL(docker-compose)---
# back/.env の DB_NAME / DB_USER / DB_PASSWORD / DB_PORT と値を揃えること
POSTGRES_DB=llmn_pipeline
POSTGRES_USER=llmn_pipeline
POSTGRES_PASSWORD=llmn_pipeline
POSTGRES_PORT=5440

# --- node-pg-migrate ---
DATABASE_URL=postgres://llmn_pipeline:llmn_pipeline@localhost:5440/llmn_pipeline
