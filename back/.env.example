# PostgreSQL 接続情報
# 既存 llamune の Docker が 5434-5439 を使用中のため、ポートは衝突しない値にすること
DB_HOST=localhost
DB_PORT=5440
DB_NAME=llmn_pipeline
DB_USER=llmn_pipeline
DB_PASSWORD=llmn_pipeline
DB_SCHEMA=rag

# API 認証(interfaces.md §7.8.5)
# カンマ区切りで複数キーを列挙できる。X-API-Key ヘッダで完全一致検証する。
# キー生成コマンド(name は用途/ユーザーの識別子に置き換える):
#   python -c "import secrets; print('llmn_{name}_' + secrets.token_hex(16))"
API_KEYS=llmn_dev_0123456789abcdef0123456789abcdef
